generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  engineType             = "client"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id          String    @id @default(cuid())
  name        String
  description String?
  shareCode   String    @unique
  startDate   DateTime?
  endDate     DateTime?
  notes       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members       Member[]
  expenses      Expense[]
  bookings      Booking[]
  photos        Photo[]
  payments      Payment[]
  storageConfig StorageConfig?
  dateVotes     DateVote[]

  @@map("trips")
}

model Member {
  id         String   @id @default(cuid())
  name       String
  joinedAt   DateTime @default(now())
  paypalLink String?

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  paidExpenses  Expense[]     @relation("PaidBy")
  splitMembers  SplitMember[]
  paymentsFrom  Payment[]     @relation("PaymentFrom")
  paymentsTo    Payment[]     @relation("PaymentTo")
  dateVotes     DateVote[]

  @@unique([tripId, name])
  @@map("members")
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  currency    String   @default("EUR")
  createdAt   DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  paidById String
  paidBy   Member @relation("PaidBy", fields: [paidById], references: [id])

  splits SplitMember[]

  @@map("expenses")
}

model SplitMember {
  id     String @id @default(cuid())
  amount Float

  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("split_members")
}

model Booking {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("other")
  reference   String?
  checkIn     DateTime?
  checkOut    DateTime?
  location    String?
  price       Float?
  currency    String    @default("EUR")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Photo {
  id         String   @id @default(cuid())
  filename   String
  url        String
  thumbnail  String?
  caption    String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model StorageConfig {
  id     String @id @default(cuid())
  type   String
  config String

  tripId String @unique
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("storage_configs")
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  createdAt DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  fromId String
  from   Member @relation("PaymentFrom", fields: [fromId], references: [id])

  toId String
  to   Member @relation("PaymentTo", fields: [toId], references: [id])

  @@map("payments")
}

model DateVote {
  id        String   @id @default(cuid())
  date      DateTime
  createdAt DateTime @default(now())

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tripId, memberId, date])
  @@map("date_votes")
}
